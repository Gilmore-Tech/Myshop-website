{
  "name": "myshop_website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://github.com/Gilmore-Tech/Myshop-website.git",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/emit-routes.mjs",
    "build:ghpages": "tsc -b && vite build --mode ghpages && node scripts/emit-routes.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist",
    "deploy:ghpages": "npm run build:ghpages && gh-pages -d dist"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
